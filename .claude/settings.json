{
  "permissions": {
    "allow": [
      "mcp__claude_ai_Supabase__get_logs",
      "mcp__claude_ai_Supabase__list_tables",
      "mcp__claude_ai_Supabase__list_migrations",
      "mcp__claude_ai_Supabase__get_advisors",
      "mcp__claude_ai_Supabase__get_project",
      "mcp__claude-in-chrome__tabs_context_mcp"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/lint-touched.sh\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "vercel-plugin@vercel-vercel-plugin": false,
    "vercel@claude-plugins-official": false
  }
}
